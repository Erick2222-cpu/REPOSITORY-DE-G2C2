<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="pe.edu.upeu.controller.DefuncionController"
            prefHeight="400.0" prefWidth="600.0">
    <!-- Título -->
    <Label text="Padrón de Defunciones"
           layoutX="180" layoutY="10"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Campos -->
    <TextField fx:id="txtNombre"
               promptText="Nombre del fallecido"
               layoutX="50" layoutY="60" prefWidth="200"/>

    <DatePicker fx:id="dpFecha"
                layoutX="300" layoutY="60" prefWidth="200"/>

    <TextField fx:id="txtLugar"
               promptText="Lugar de defunción"
               layoutX="50" layoutY="110" prefWidth="200"/>

    <TextField fx:id="txtCausa"
               promptText="Causa de muerte"
               layoutX="300" layoutY="110" prefWidth="200"/>

    <TextField fx:id="txtFamiliar"
               promptText="Nombre del familiar"
               layoutX="50" layoutY="160" prefWidth="200"/>
    <TextField fx:id="txtParentesco"
               promptText="Parentesco"
               layoutX="300" layoutY="160" prefWidth="200"/>

    <!-- Botones -->
    <Button text="Guardar"
            layoutX="100" layoutY="210"
            onAction="#guardar"/>

    <Button text="Actualizar"
            layoutX="240" layoutY="210"
            onAction="#actualizar"/>

    <Button text="Eliminar"
            layoutX="400" layoutY="210"
            onAction="#eliminar"/>

    <!-- Lista -->
    <ListView fx:id="listView"
              layoutX="50" layoutY="260"
              prefWidth="450" prefHeight="150"
              onMouseClicked="#seleccionar"/>

</AnchorPane>

